# PostgreSQL connection string. Use Neon pooled connection string for Vercel.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/sixram_nextgen_autohub?schema=public"

# JWT compatibility values for the existing .NET API migration.
# Replace with production-grade secret management before deployment.
JWT_SECRET="replace-with-at-least-32-characters"
JWT_ISSUER="sixram.nextgen"
JWT_AUDIENCE="sixram.nextgen.web"
JWT_EXPIRY_MINUTES="60"
PASSWORD_HASHING_ITERATIONS="100000"

# External integrations.
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5.2"

# Object storage placeholder. Choose Vercel Blob, S3, R2, or Azure Blob before file-heavy modules.
STORAGE_PROVIDER="local"
STORAGE_BUCKET=""
STORAGE_PUBLIC_BASE_URL=""

# Hikvision migration placeholders.
HIKVISION_WEBHOOK_SECRET=""
HIKVISION_GATEWAY_BASE_URL=""
