  LaborDiscountRate      Decimal   @db.Decimal(18, 2)
  ProductDiscountRate    Decimal   @db.Decimal(18, 2)
  IsVATExempt            Boolean
  IsAllowWithholidingTax Boolean
  CreatedById            Int
  CreatedDateTime        DateTime  @db.Timestamp(3)
  UpdatedById            Int
  UpdatedDateTime        DateTime  @db.Timestamp(3)

  DepositsAsCustomer    Deposit[]    @relation("FK_Deposit_Customer")
  EstimatesAsCustomer   Estimate[]   @relation("FK_Estimate_Customer")
  InspectionsAsCustomer Inspection[] @relation("FK_Inspection_Customer")
  InvoicesAsCustomer    Invoice[]    @relation("FK_Invoice_Customer")
