generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// Phase 1 schema draft:
// - Scalar EF Core fields are represented for all known entities.
// - Prisma relation fields are intentionally deferred until live MSSQL table
//   names, FK constraints, and delete behaviors are validated.
// - PostgreSQL partial indexes must be added in raw SQL migrations.

model CameraEvent {
  Id                       Int       @id @default(autoincrement())
  CameraIp                 String?   @db.VarChar(64)
  Ipv6Address              String?   @db.VarChar(80)
  PortNo                   Int?
  Protocol                 String?   @db.VarChar(20)
  MacAddress               String?   @db.VarChar(32)
  ChannelId                Int?
  ChannelName              String?   @db.VarChar(100)
  EventDateTime            DateTime  @db.Timestamptz(3)
  EventType                String    @db.VarChar(80)
  EventState               String    @db.VarChar(30)
  EventDescription         String?   @db.VarChar(200)
  ActivePostCount          Int?
  Source                   String?   @db.VarChar(80)
  SnapshotPath             String?   @db.VarChar(300)
  SnapshotUrl              String?   @db.VarChar(300)
  SnapshotCapturedDateTime DateTime? @db.Timestamp(3)
  SnapshotError            String?   @db.VarChar(500)
  RawXml                   String    @db.Text
  CreatedDateTime          DateTime  @db.Timestamp(3)

  @@index([EventDateTime], map: "IX_CameraEvents_EventDateTime")
  @@index([EventType, EventState, EventDateTime], map: "IX_CameraEvents_Type_State_DateTime")
  @@index([CameraIp, EventDateTime], map: "IX_CameraEvents_CameraIp_EventDateTime")
  @@map("CameraEvents")
}

